# J.A.R.V.I.S. Environment Variables
# Copy this file to .env and fill in your values

# ─── Android Build ───
# Used in app/build.gradle.kts for compile-time injection
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Relay Server (jarvis-relay/) ───
PORT=3000
# Optional: Set a secret for relay authentication
# RELAY_SECRET=your_relay_secret_here

# ─── MCP Server (mcp-server/) ───
# Relay URL the MCP server connects to
RELAY_URL=https://j-a-r-v-i-s-ktlh.onrender.com
