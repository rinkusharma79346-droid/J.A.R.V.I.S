<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_black">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="J.A.R.V.I.S."
        android:textColor="@color/cyan_accent"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/glass_card"
        android:orientation="vertical"
        android:padding="16dp">
        <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Service: Disconnected" android:textColor="@color/white" />
        <TextView android:id="@+id/tvStep" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Step: 0/50" android:textColor="@color/gray" />
        <TextView android:id="@+id/tvAction" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Action: Idle" android:textColor="@color/cyan_accent" android:textStyle="bold" android:layout_marginTop="8dp"/>
    </LinearLayout>

    <EditText
        android:id="@+id/etTask"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter objective..."
        android:textColorHint="@color/gray"
        android:textColor="@color/white"
        android:background="@drawable/glass_card"
        android:padding="16dp"
        android:layout_marginTop="24dp" />

    <Button
        android:id="@+id/btnExecute"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="EXECUTE"
        android:backgroundTint="@color/cyan_accent"
        android:textColor="@color/bg_black"
        android:textStyle="bold"
        android:layout_marginTop="16dp" />
        
    <Button
        android:id="@+id/btnPerms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="GRANT PERMISSIONS"
        android:backgroundTint="@color/glass_white"
        android:textColor="@color/white"
        android:layout_marginTop="8dp" />

</LinearLayout>
