<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_gradient"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="24dp">

        <!-- ═══ Top Bar ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvApiKeyStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="● API Key"
                android:textColor="@color/green_accent"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <!-- MCP indicator dot + label -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginEnd="10dp">

                <View
                    android:id="@+id/mcpDot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/mcp_indicator_off"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tvRelayStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MCP"
                    android:textColor="@color/gray"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvApiProvider"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="API: Gemini / gemini-2.0-flash"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_preferences"
                android:background="@drawable/btn_glass"
                android:contentDescription="Settings"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="@color/cyan_primary" />
        </LinearLayout>

        <!-- ═══ JARVIS Title with Glow ═══ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/ivGlow"
                android:layout_width="320dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:src="@drawable/glow_circle"
                android:scaleType="fitCenter"
                android:alpha="0.4" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="J.A.R.V.I.S."
                    android:textColor="@color/cyan_primary"
                    android:textSize="38sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:shadowColor="@color/cyan_glow"
                    android:shadowRadius="24" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AUTONOMOUS NEURAL ENGINE"
                    android:textColor="@color/cyan_dim"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.35"
                    android:layout_marginTop="-2dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- ═══ Status Card ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <!-- Section header with status dot -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <View
                    android:id="@+id/statusDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/status_dot_idle"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SYSTEM STATUS"
                    android:textColor="@color/text_dim"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.25" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ready — Service Disconnected"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvStep"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="IDLE"
                    android:textColor="@color/cyan_primary"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50 max"
                    android:textColor="@color/text_dim"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/cyan_primary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginTop="8dp"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- MCP Relay detail -->
            <TextView
                android:id="@+id/tvRelayDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/gray"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:layout_marginTop="6dp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- ═══ Task Input Card ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OBJECTIVE"
                android:textColor="@color/text_dim"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.25"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etTask"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:hint="Enter task for JARVIS..."
                android:textColorHint="@color/text_dim"
                android:textColor="@color/white"
                android:background="@drawable/edittext_glass"
                android:padding="14dp"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:gravity="top|start"
                android:importantForAutofill="no" />
        </LinearLayout>

        <!-- ═══ Action Buttons ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnExecute"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="EXECUTE"
                android:background="@drawable/btn_cyan"
                android:textColor="#050510"
                android:textStyle="bold"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="KILL"
                android:background="@drawable/btn_red"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:alpha="0.4"
                android:enabled="false"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnPerms"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="GRANT PERMISSIONS"
            android:background="@drawable/btn_glass"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.12" />

        <!-- ═══ Bottom Info Bar ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:gravity="center">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Grant Accessibility + Overlay permissions for the agent to work."
                android:textColor="@color/text_faint"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JARVIS v3.0 · Neural Engine"
                android:textColor="@color/text_faint"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:layout_marginTop="8dp"
                android:letterSpacing="0.1" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
