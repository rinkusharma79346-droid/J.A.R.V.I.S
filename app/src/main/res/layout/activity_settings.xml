<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="24dp">
            <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_revert" android:background="@drawable/btn_glass" android:contentDescription="Back" android:padding="10dp" android:scaleType="fitCenter" app:tint="@color/text_primary" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SETTINGS" android:textColor="@color/orange_primary" android:textSize="20sp" android:fontFamily="monospace" android:textStyle="bold" android:letterSpacing="0.15" android:gravity="center" />
            <View android:layout_width="40dp" android:layout_height="40dp" android:visibility="invisible" />
        </LinearLayout>

        <!-- API Provider Section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/glass_card" android:orientation="vertical" android:padding="20dp" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI PROVIDER" android:textColor="@color/orange_primary" android:textSize="9sp" android:fontFamily="monospace" android:letterSpacing="0.2" android:layout_marginBottom="12dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Provider" android:textColor="@color/text_secondary" android:textSize="12sp" android:fontFamily="monospace" android:layout_marginBottom="6dp" />
            <Spinner android:id="@+id/spinnerProvider" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/spinner_glass" android:popupBackground="#1A1A1210" android:textColor="@color/text_primary" android:textSize="13sp" android:fontFamily="monospace" android:layout_marginBottom="16dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="API Key" android:textColor="@color/text_secondary" android:textSize="12sp" android:fontFamily="monospace" android:layout_marginBottom="6dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                <EditText android:id="@+id/etApiKey" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:background="@drawable/edittext_glass" android:hint="Paste your API key..." android:textColorHint="@color/text_dim" android:textColor="@color/text_primary" android:textSize="12sp" android:fontFamily="monospace" android:padding="12dp" android:inputType="textVisiblePassword" android:singleLine="true" android:layout_marginEnd="8dp" android:importantForAutofill="no" />
                <Button android:id="@+id/btnDetect" android:layout_width="wrap_content" android:layout_height="44dp" android:text="DETECT" android:background="@drawable/btn_glass" android:textColor="@color/orange_primary" android:textSize="10sp" android:fontFamily="monospace" android:paddingHorizontal="12dp" android:minWidth="80dp" />
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Model" android:textColor="@color/text_secondary" android:textSize="12sp" android:fontFamily="monospace" android:layout_marginBottom="6dp" />
            <Spinner android:id="@+id/spinnerModel" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/spinner_glass" android:popupBackground="#1A1A1210" android:textColor="@color/text_primary" android:textSize="12sp" android:fontFamily="monospace" android:layout_marginBottom="16dp" />
            <TextView android:id="@+id/tvBaseUrlLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Base URL" android:textColor="@color/text_secondary" android:textSize="12sp" android:fontFamily="monospace" android:layout_marginBottom="6dp" android:visibility="gone" />
            <EditText android:id="@+id/etBaseUrl" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/edittext_glass" android:hint="https://api.openai.com/v1" android:textColorHint="@color/text_dim" android:textColor="@color/text_primary" android:textSize="12sp" android:fontFamily="monospace" android:padding="12dp" android:inputType="textUri" android:singleLine="true" android:visibility="gone" android:importantForAutofill="no" />
            <Button android:id="@+id/btnValidate" android:layout_width="match_parent" android:layout_height="44dp" android:text="TEST CONNECTION" android:background="@drawable/btn_orange" android:textColor="#1A1210" android:textSize="12sp" android:fontFamily="monospace" android:textStyle="bold" android:letterSpacing="0.1" android:layout_marginTop="4dp" />
            <TextView android:id="@+id/tvValidationResult" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="" android:textColor="@color/green_accent" android:textSize="11sp" android:fontFamily="monospace" android:layout_marginTop="8dp" android:visibility="gone" />
        </LinearLayout>

        <!-- MCP Relay Section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/glass_card" android:orientation="vertical" android:padding="20dp" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MCP RELAY" android:textColor="@color/orange_primary" android:textSize="9sp" android:fontFamily="monospace" android:letterSpacing="0.2" android:layout_marginBottom="12dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <Switch android:id="@+id/switchRelay" android:layout_width="wrap_content" android:layout_height="wrap_content" android:trackTint="@color/orange_primary" android:thumbTint="@color/orange_primary" android:layout_marginEnd="12dp" />
                <TextView android:id="@+id/tvRelayStatus" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="○ Disconnected" android:textColor="@color/gray" android:textSize="12sp" android:fontFamily="monospace" />
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Relay Server URL" android:textColor="@color/text_secondary" android:textSize="12sp" android:fontFamily="monospace" android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etRelayUrl" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/edittext_glass" android:hint="https://your-relay.onrender.com" android:textColorHint="@color/text_dim" android:textColor="@color/text_primary" android:textSize="12sp" android:fontFamily="monospace" android:padding="12dp" android:inputType="textUri" android:singleLine="true" android:importantForAutofill="no" android:layout_marginBottom="10dp" />
            <Button android:id="@+id/btnTestRelay" android:layout_width="match_parent" android:layout_height="40dp" android:text="TEST RELAY CONNECTION" android:background="@drawable/btn_glass" android:textColor="@color/orange_primary" android:textSize="11sp" android:fontFamily="monospace" android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- Agent Settings -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/glass_card" android:orientation="vertical" android:padding="20dp" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AGENT CONFIG" android:textColor="@color/orange_primary" android:textSize="9sp" android:fontFamily="monospace" android:letterSpacing="0.2" android:layout_marginBottom="12dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Max Steps (ReAct Loop Limit)" android:textColor="@color/text_secondary" android:textSize="12sp" android:fontFamily="monospace" android:layout_marginBottom="6dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <SeekBar android:id="@+id/seekMaxSteps" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:min="10" android:max="100" android:progress="50" android:progressTint="@color/orange_primary" android:thumbTint="@color/orange_primary" />
                <TextView android:id="@+id/tvMaxStepsValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="50 steps" android:textColor="@color/orange_primary" android:textSize="12sp" android:fontFamily="monospace" android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Auto-detect: AIza...→Gemini | sk-...→OpenAI | nvapi-...→NVIDIA" android:textColor="#33D4B5A5" android:textSize="10sp" android:fontFamily="monospace" android:lineSpacingExtra="3dp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="MCP: Connect your AI client via the relay for remote control" android:textColor="#33D4B5A5" android:textSize="10sp" android:fontFamily="monospace" android:lineSpacingExtra="3dp" android:layout_marginTop="6dp" />
    </LinearLayout>
</ScrollView>
